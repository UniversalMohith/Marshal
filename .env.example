# Copy to .env and fill in. .env is gitignored.

# Microsoft Foundry project endpoint, from the Foundry portal welcome screen.
# Format: https://<resource>.ai.azure.com/api/projects/<project>
PROJECT_ENDPOINT=

# Foundry IQ grounding (the Microsoft IQ layer). Set BOTH to activate; leave blank
# to run with local grounding only. SEARCH_ENDPOINT is your Azure AI Search service
# URL (https://<service>.search.windows.net); KNOWLEDGE_BASE is the knowledge base
# name you created in Foundry IQ. Auth uses DefaultAzureCredential (run: az login).
SEARCH_ENDPOINT=
KNOWLEDGE_BASE=

# Model deployments (the model names you deployed in Foundry).
ORCHESTRATOR_MODEL=gpt-5.4-mini
WORKER_MODEL=gpt-5.4-mini
CRITIC_MODEL=gpt-5.4-mini
SYNTHESISER_MODEL=gpt-5.4-mini

# Budget governor (per question).
BUDGET_USD=0.50
BUDGET_RESERVE_FRAC=0.15

# Swarm sizing and self-correction.
MAX_WORKERS=5
MAX_SELF_CORRECTIONS=2
STUB_MIN_CHARS=400

# Prefix for the agent names created in your Foundry project.
AGENT_PREFIX=marshal
